<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>
            [FrasesRandomAPI.UnitTests]*,
            [FrasesRandomAPI.IntegrationTests]*,
            [FrasesRandomAPI.Benchmarks]*,
            [*]*.SourceGenerators*,
            [*]*.AssemblyInfo,
            [*]*.GlobalUsings,
            [*]Microsoft.AspNetCore*,
            [*]Microsoft.EntityFrameworkCore*
            */obj/**
            */bin/**
          </Exclude>
          <ExcludeByAttribute>
            ExcludeFromCodeCoverage
          </ExcludeByAttribute>
          <IncludeStaticMembers>false</IncludeStaticMembers>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
